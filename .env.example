# Copy this file to `.env` and fill these in from your Supabase project.
# Supabase Dashboard -> Project Settings -> API
#
# IMPORTANT:
# - Use the Project URL for EXPO_PUBLIC_SUPABASE_URL.
# - Use the anon/public/publishable key for EXPO_PUBLIC_SUPABASE_ANON_KEY.
# - NEVER put the service_role key in this mobile app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
