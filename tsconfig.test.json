{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2020",
    "outDir": ".test-build",
    "rootDir": ".",
    "noEmit": false,
    "jsx": "react-jsx",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/types.ts", "src/utils/**/*.ts", "tests/**/*.ts"]
}
